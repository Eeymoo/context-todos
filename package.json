{
  "name": "@eeymoo/context-todos",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "MCP server for scanning and managing TODO/FIXME/HACK/XXX comments in your codebase",
  "author": "eeymoo",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eeymoo/context-todos"
  },
  "bugs": {
    "url": "https://github.com/Eeymoo/context-todos/issues"
  },
  "homepage": "https://github.com/Eeymoo/context-todos#readme",
  "bin": {
    "context-todos": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts mcp",
    "start": "node dist/index.js mcp",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspector": "pnpm dlx @modelcontextprotocol/inspector node dist/index.js mcp",
    "inspector:dev": "pnpm dlx @modelcontextprotocol/inspector tsx src/index.ts mcp",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "todo",
    "fixme",
    "code-scanner",
    "code-analysis",
    "ai-tools"
  ],
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "ignore": "^7.0.5",
    "leasot": "^14.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
